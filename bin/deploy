#!/bin/bash
# Deploy homelab-horizon to a host.
#
# Usage:
#   ./bin/deploy --host ubuntu@1.2.3.4               # local build (dev loop)
#   ./bin/deploy --host ubuntu@1.2.3.4 --version v0.0.1  # GitHub release
#
# --version: target curls the matching prebuilt archive from the GitHub
#            release. No local toolchain needed; binary is exactly what
#            'bin/release' published.
# (default): cross-compile the working tree locally and scp. Faster turn-
#            around and lets you ship un-tagged WIP fixes.

set -euo pipefail

DEFAULT_HOST="ubuntu@192.168.1.89"
HOST="$DEFAULT_HOST"
VERSION=""

usage() {
  cat <<HELP
Usage: $0 [--host USER@HOST] [--version vX.Y.Z]

  --host       SSH target (default: $DEFAULT_HOST)
  --version    GitHub release tag to deploy; omit for local build
  -h, --help   Show this help
HELP
}

while [ $# -gt 0 ]; do
  case "$1" in
    --host)
      [ $# -ge 2 ] || { echo "--host needs a value" >&2; exit 2; }
      HOST="$2"; shift 2 ;;
    --version)
      [ $# -ge 2 ] || { echo "--version needs a value" >&2; exit 2; }
      VERSION="$2"; shift 2 ;;
    -h|--help)
      usage; exit 0 ;;
    *)
      echo "unknown arg: $1" >&2; usage >&2; exit 2 ;;
  esac
done

[ -n "$HOST" ] || { echo "--host required" >&2; exit 2; }

if [ -n "$VERSION" ] && ! [[ "$VERSION" =~ ^v[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo "--version must be vMAJOR.MINOR.PATCH (got $VERSION)" >&2
  exit 2
fi

echo "Detecting architecture on $HOST..."
UNAME_M=$(ssh "$HOST" "uname -m" 2>/dev/null || echo "unknown")
case "$UNAME_M" in
  x86_64)        ARCH="linux-amd64" ;;
  aarch64|arm64) ARCH="linux-arm64" ;;
  armv7l|armv6l) ARCH="linux-armv7" ;;
  *)
    echo "Unsupported arch ($UNAME_M) — falling back to linux-arm64" >&2
    ARCH="linux-arm64"
    ;;
esac
echo "Architecture: $ARCH"

REMOTE_PATH="/usr/local/bin/homelab-horizon"

# Stage /tmp/homelab-horizon.new on the target via one of two paths.
if [ -z "$VERSION" ]; then
  echo "Building $ARCH locally..."
  make build-"$ARCH"
  scp "dist/homelab-horizon-$ARCH" "$HOST:/tmp/homelab-horizon.new"
else
  # Derive owner/repo from the git origin so this script keeps working if
  # the repo gets forked or moved — no hardcoded slug to drift.
  repo=$(git remote get-url origin 2>/dev/null \
    | sed -E 's|.*github.com[:/]([^/]+/[^/.]+)(\.git)?$|\1|')
  [ -n "$repo" ] || { echo "could not derive repo from git origin" >&2; exit 1; }
  url="https://github.com/$repo/releases/download/$VERSION/homelab-horizon-$ARCH.tar.gz"
  echo "Fetching $url on $HOST..."
  # curl -f turns a 404 (bad tag) into a non-zero exit instead of writing
  # the HTML error page to disk and "succeeding".
  ssh "$HOST" "set -e
    cd /tmp
    curl -fSL -o homelab-horizon-$ARCH.tar.gz '$url'
    tar -xzf homelab-horizon-$ARCH.tar.gz
    mv homelab-horizon-$ARCH homelab-horizon.new
    rm -f homelab-horizon-$ARCH.tar.gz
  "
fi

echo "Installing on $HOST..."
ssh "$HOST" -t "
  sudo mv /tmp/homelab-horizon.new $REMOTE_PATH
  sudo chmod +x $REMOTE_PATH

  echo 'Installing systemd service using binary...'
  sudo mkdir -p /etc/homelab-horizon
  cd /etc/homelab-horizon
  sudo $REMOTE_PATH -install

  echo 'Enabling and restarting service...'
  sudo systemctl enable homelab-horizon
  sudo systemctl daemon-reload
  if sudo systemctl restart homelab-horizon; then
    echo 'Checking status...'
    sudo systemctl status homelab-horizon --no-pager -l | head -20

    echo ''
    echo 'Auth token:'
    for i in {1..5}; do
      if [ -f /etc/homelab-horizon/config.json.token ]; then
        sudo cat /etc/homelab-horizon/config.json.token
        break
      fi
      sleep 1
    done || echo '(token file not found)'
  else
    echo ''
    echo '*** SERVICE FAILED TO START ***'
    echo ''
    sudo systemctl status homelab-horizon --no-pager -l
    echo ''
    echo '--- Journal (last 30 lines) ---'
    sudo journalctl -u homelab-horizon -n 30 --no-pager -o short
    exit 1
  fi
"

echo ""
echo "Done!"
